SERVER_PORT=8080

DB_URL=jdbc:mysql://localhost:3306/drawbridge_db?createDatabaseIfNotExist=true
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password

JWT_SECRET=replace-with-your-team-jwt-secret-at-least-32-characters
JWT_EXPIRATION_MS=86400000

UPLOAD_DIR=./uploads

APP_BASE_URL=http://localhost:3000

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Mailtrap — get your token at https://mailtrap.io → API Tokens
# For local development: set MAILTRAP_SANDBOX=true and supply your inbox ID
# For production: set MAILTRAP_SANDBOX=false (or omit it) and use a sending domain token
MAILTRAP_API_TOKEN=your_mailtrap_api_token_here
MAILTRAP_SANDBOX=true
MAILTRAP_INBOX_ID=0
# Keep this low on free plans to avoid: "Too many emails per second"
MAILTRAP_MAX_EMAILS_PER_SECOND=1
MAILTRAP_MAX_RETRIES=4
MAILTRAP_RETRY_BASE_DELAY_MS=5000

