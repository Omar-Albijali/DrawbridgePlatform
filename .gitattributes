# Normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly set LF for source files
*.kt    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf

# Binary files - no conversion
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.jar   binary